SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
AUTH_REDIRECT_SCHEME=gymunity
AUTH_REDIRECT_HOST=auth-callback
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID
GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID
GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID

# Supabase Edge Function secrets for Azure AI / Azure Foundry.
# Set these with `supabase secrets set`; do not put real secrets in Flutter
# config or committed files.
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://YOUR_PROJECT.services.ai.azure.com/api/projects/YOUR_PROJECT
AZURE_FOUNDRY_API_VERSION=v1
AZURE_FOUNDRY_ORCHESTRATOR_AGENT_ID=YOUR_TAIYO_ORCHESTRATOR_AGENT_ID
# Or use AZURE_FOUNDRY_ORCHESTRATOR_AGENT_NAME instead of the ID.
# AZURE_FOUNDRY_ORCHESTRATOR_AGENT_NAME=TAIYO Orchestrator Agent
# Backward-compatible fallback for older Edge Functions.
# AZURE_FOUNDRY_AGENT_ID=YOUR_TAIYO_AGENT_ID
# AZURE_FOUNDRY_AGENT_NAME=TAIYO Orchestrator
TAIYO_ACTION_SECRET=YOUR_LONG_RANDOM_ACTION_SECRET
TAIYO_CONTEXT_TOKEN_SECRET=YOUR_LONG_RANDOM_CONTEXT_TOKEN_SECRET_AT_LEAST_24_CHARS
# Auth option 1: Entra service principal.
AZURE_TENANT_ID=YOUR_AZURE_TENANT_ID
AZURE_CLIENT_ID=YOUR_AZURE_CLIENT_ID
AZURE_CLIENT_SECRET=YOUR_AZURE_CLIENT_SECRET
# Auth option 2: static bearer token if your Foundry setup uses one.
# AZURE_FOUNDRY_AGENT_TOKEN=YOUR_AZURE_AGENT_TOKEN

# Supabase Edge Function secrets for Paymob TEST MODE only.
# Set these with `supabase secrets set`; do not put real secrets in Flutter
# config or committed files.
PAYMOB_MODE=test
PAYMOB_API_BASE_URL=https://accept.paymob.com
PAYMOB_MERCHANT_ID=YOUR_PAYMOB_TEST_MERCHANT_ID
PAYMOB_TEST_INTEGRATION_IDS=YOUR_PAYMOB_TEST_INTEGRATION_ID
PAYMOB_CURRENCY=EGP
PAYMOB_PUBLIC_KEY_TEST=YOUR_PAYMOB_TEST_PUBLIC_KEY
PAYMOB_SECRET_KEY_TEST=YOUR_PAYMOB_TEST_SECRET_KEY
PAYMOB_HMAC_SECRET_TEST=YOUR_PAYMOB_TEST_HMAC_SECRET
PAYMOB_NOTIFICATION_URL=https://YOUR_PROJECT_REF.functions.supabase.co/paymob-transaction-callback
APP_PUBLIC_PAYMENT_REDIRECT_URL=https://YOUR_PROJECT_REF.functions.supabase.co/paymob-payment-response
GYMUNITY_PLATFORM_FEE_BPS=1500
GYMUNITY_PAYOUT_HOLD_DAYS=0
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_FOR_EDGE_FUNCTIONS_ONLY
